# ByteOath Site — Environment Variables
# Copy this to .env and edit values before starting

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
CONTACT_EMAIL=hello@byteoath.com

# ── Docker ────────────────────────────────────────────────────────────────────
SITE_PORT=3000               # host port nginx listens on

# ── Admin panel ───────────────────────────────────────────────────────────────
# Generate a new password hash:  php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
ADMIN_USER=admin
ADMIN_PASS_HASH=$2y$10$6IH4aoGWi47cBF0Bv31K7.uiMw6hDOc1JePu/1pa8IpHgjGXARGe2
# Default password: ByteOath2024!  ← CHANGE BEFORE GOING LIVE

# ── Placeholder URLs (fill before launch) ─────────────────────────────────────
APP_STORE_URL=
GITHUB_URL=
LINKEDIN_URL=

